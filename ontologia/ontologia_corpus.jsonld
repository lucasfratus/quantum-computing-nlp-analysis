    {
      "@id": "http://example.org/trab2-ia/lucas-matheus/quantum-computing-nlp-analysis/artigo/s41598-026-40634-z-pdf",
      "@type": [
        "ArtigoCientifico",
        "schema:ScholarlyArticle"
      ],
      "arquivo": "s41598-026-40634-z.pdf",
      "titulo": "Quantum transfer learning for",
      "temObjetivo": [
        {
          "@id": "http://example.org/trab2-ia/lucas-matheus/quantum-computing-nlp-analysis/artigo/s41598-026-40634-z-pdf/objetivo/1",
          "@type": "TrechoExtraido",
          "categoria": "objetivo",
          "ordem": 1,
          "texto": "This study proposes a framework that uses quantum transfer learning to enhance cybersecurity threat detection by leveraging multiple datasets, including UNSWNB15, CICIDS2017, CSE-CIC-IDS2018, and TON_Io T."
        },
        {
          "@id": "http://example.org/trab2-ia/lucas-matheus/quantum-computing-nlp-analysis/artigo/s41598-026-40634-z-pdf/objetivo/2",
          "@type": "TrechoExtraido",
          "categoria": "objetivo",
          "ordem": 2,
          "texto": "The objective of this research is to investigate the feasibility and potential benefits of integrating quantum transfer learning into intrusion detection systems, thereby bridging the gap between classical machine learning limitations and the emerging capabilities of quantum computing."
        },
        {
          "@id": "http://example.org/trab2-ia/lucas-matheus/quantum-computing-nlp-analysis/artigo/s41598-026-40634-z-pdf/objetivo/3",
          "@type": "TrechoExtraido",
          "categoria": "objetivo",
          "ordem": 3,
          "texto": "The major contributions of this research are as follows: • This study proposes a novel hybrid quantum transfer learning framework that integrates classical pre-trained models with variational quantum circuits for intrusion detection. • Progressive transfer learning is demonstrated across multiple benchmark cybersecurity datasets (UN SW-NB15 → CICIDS2017/CSE-CIC-IDS2018 → TON_Io T), improving model generalization without full retraining."
        }
      ],
      "temProblema": [
        {
          "@id": "http://example.org/trab2-ia/lucas-matheus/quantum-computing-nlp-analysis/artigo/s41598-026-40634-z-pdf/problema/1",
          "@type": "TrechoExtraido",
          "categoria": "problema",
          "ordem": 1,
          "texto": "However, existing quantum-enhanced intrusion detection systems typically employ quantum models only at the classification stage or rely on standalone quantum architectures, while transfer learning-based IDS remain limited to classical-to-classical knowledge reuse."
        },
        {
          "@id": "http://example.org/trab2-ia/lucas-matheus/quantum-computing-nlp-analysis/artigo/s41598-026-40634-z-pdf/problema/2",
          "@type": "TrechoExtraido",
          "categoria": "problema",
          "ordem": 2,
          "texto": "Despite these advances, classical AI-based models often struggle with highdimensional cybersecurity datasets, heterogeneous feature spaces, and generalization across different network environments13,14."
        },
        {
          "@id": "http://example.org/trab2-ia/lucas-matheus/quantum-computing-nlp-analysis/artigo/s41598-026-40634-z-pdf/problema/3",
          "@type": "TrechoExtraido",
          "categoria": "problema",
          "ordem": 3,
          "texto": "Quantum transfer learning for cross-domain cybersecurity threat detection and categorization Shtwai Alsubai1, Mohamed Ayari2, Natalia Kryvinska3, Ahmad Almadhor4, Jamel Baili5, Abdullah Al Hejaili6 & Sidra Abbas7 Cybersecurity challenges have become increasingly complex and widespread, and the risks associated with these problems are substantial, affecting thousands of individuals and organisations and being crucial to national security."
        },
        {
          "@id": "http://example.org/trab2-ia/lucas-matheus/quantum-computing-nlp-analysis/artigo/s41598-026-40634-z-pdf/problema/4",
          "@type": "TrechoExtraido",
          "categoria": "problema",
          "ordem": 4,
          "texto": "The objective of this research is to investigate the feasibility and potential benefits of integrating quantum transfer learning into intrusion detection systems, thereby bridging the gap between classical machine learning limitations and the emerging capabilities of quantum computing."
        }
      ],
      "temMetodologia": [
        {
          "@id": "http://example.org/trab2-ia/lucas-matheus/quantum-computing-nlp-analysis/artigo/s41598-026-40634-z-pdf/metodo/1",
          "@type": "TrechoExtraido",
          "categoria": "metodo",
          "ordem": 1,
          "texto": "Class weights were computed separately for each dataset used in the experiments, adapting to each dataset’s class distribution to maintain fair representation."
        },
        {
          "@id": "http://example.org/trab2-ia/lucas-matheus/quantum-computing-nlp-analysis/artigo/s41598-026-40634-z-pdf/metodo/2",
          "@type": "TrechoExtraido",
          "categoria": "metodo",
          "ordem": 2,
          "texto": "In Phase 1, PCA, feature selection, encoding, scaling, and dimensionality reduction are performed on the UNSW NB15 dataset."
        },
        {
          "@id": "http://example.org/trab2-ia/lucas-matheus/quantum-computing-nlp-analysis/artigo/s41598-026-40634-z-pdf/metodo/3",
          "@type": "TrechoExtraido",
          "categoria": "metodo",
          "ordem": 3,
          "texto": "In Phase 2, UNSWNB15 and CSE-CIC-IDS2018 are used to create a dataset with the same formatting as UNSW-NB15, ensuring that features are compatible across the datasets."
        },
        {
          "@id": "http://example.org/trab2-ia/lucas-matheus/quantum-computing-nlp-analysis/artigo/s41598-026-40634-z-pdf/metodo/4",
          "@type": "TrechoExtraido",
          "categoria": "metodo",
          "ordem": 4,
          "texto": "A data pre-processing pipeline is applied to the dataset."
        }
      ],
